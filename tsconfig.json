{
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ],
  "compilerOptions": {
    "baseUrl": ".", // required for paths to work
    "paths": {
      "@components/*": [
        "src/components/*"
      ],
      "@utils/*": [
